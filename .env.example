# ------------------------------------------------------------------
# Servey website — environment variables
# Copy to `.env.local` and fill in the provider you want. Never commit secrets.
# ------------------------------------------------------------------

# Which waitlist backend to use. Optional — auto-detected from the vars below.
# One of: firebase | formspree | resend | console
# `console` (the default when nothing is configured) just logs signups and
# succeeds, so the form works out of the box in development.
# WAITLIST_PROVIDER=firebase

# --- Option A: Firebase (recommended — Servey already uses Firebase) ---------
# Service-account credentials for the Firebase Admin SDK. Signups are written to
# a `waitlist` collection, de-duped by normalized email (doc id = the email).
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
# Paste the private key with literal \n escapes, wrapped in double quotes:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# --- Option B: Formspree (zero-backend fallback) -----------------------------
# Create a form at https://formspree.io and paste its endpoint URL.
# FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx

# --- Option C: Resend Audiences (zero-backend fallback) ----------------------
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
